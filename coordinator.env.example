# Copy to coordinator.env (gitignored) on the machine running serve.py
# (your Mac). Powers the explorer "Shadow Coordination" panel.
#
#   cp coordinator.env.example coordinator.env
#   # fill in the values, then restart serve.py
#
# COORDINATOR_URL  -- the coordinator over WireGuard (hub = ree-cloud-1).
# COORDINATOR_LOCAL_TOKEN -- the bearer token minted for THIS machine
#   (the Mac, DLAPTOP-4.local) via coordinator/deploy/gen_token.py. serve.py
#   injects it into the local runner's shadow env AND uses it to read
#   /shadow/status for the panel verdict (any worker token authorizes reads).
# COORDINATOR_SSH_USER -- ssh user for the cloud boxes (default: ree).
# SHADOW_SSH_HOST_<name> -- the address serve.py should SSH to for that
#   cloud box when the Start button kicks it. Bare names like
#   'ree-cloud-1' do NOT resolve on the Mac, so set these to the
#   WireGuard tunnel IPs (the clean, stable answer once WG is up) or to
#   ssh-config aliases / public IPs. If unset, the bare name is used
#   (so an unreachable box is just reported FAILED -- never fatal).
#
# Process env vars of the same name override these.

COORDINATOR_URL=http://10.8.0.1:8787
COORDINATOR_LOCAL_TOKEN=
COORDINATOR_SSH_USER=ree
SHADOW_SSH_HOST_ree-cloud-1=10.8.0.1
SHADOW_SSH_HOST_ree-cloud-2=10.8.0.12
SHADOW_SSH_HOST_ree-cloud-3=10.8.0.13
SHADOW_SSH_HOST_ree-cloud-4=10.8.0.14
